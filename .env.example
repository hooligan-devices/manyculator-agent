# Local development configuration
# For deployment, these are set via Terraform / the deploy command.

# Vertex AI Configuration (default)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Third-party LLM models API keys (LiteLLM)

# OpenRouter API Key (required if using OpenRouter models via LiteLLM)
# OPENROUTER_API_KEY="your_api_key_here"

# Anthropic API Key (required if using Anthropic models natively via LiteLLM)
# ANTHROPIC_API_KEY="your_api_key_here"

# OpenAI API Key (required if using OpenAI models natively via LiteLLM)
# OPENAI_API_KEY="your_api_key_here"
